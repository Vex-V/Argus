# PostgreSQL runs in Docker as standby infra (nothing writes to it yet).
DATABASE_URL=postgresql://argus:argus_dev@localhost:5432/argus

# --- Telegram provider (https://my.telegram.org/apps) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=argus_telegram

# --- Reddit provider (official API is gated; RedScrapsLib scrapes via an ---
# --- authenticated browser session instead — log into reddit.com in the  ---
# --- browser named below first. Rate-limited to ~100 calls/hour.         ---
# Must be a valid RFC 7230 product token (no colons) — RedScrapsLib's .NET
# backend rejects the "app:v1 (by /u/user)" format Reddit's own docs suggest.
REDDIT_USER_AGENT=ArgusSOCMINT/0.1
REDDIT_COOKIE_BROWSER=firefox

# --- Maigret provider ---
MAIGRET_TOP_SITES=100

# --- Moriarty provider ---
# Path to the local Moriarty-Project clone (defaults to ./external/Moriarty-Project).
MORIARTY_PROJECT_PATH=
# Truecaller "FindOwner" (Truecaller via Google login) — optional, use a
# disposable/burner Google account. Feature is skipped when unset.
MORIARTY_GOOGLE_EMAIL=
MORIARTY_GOOGLE_PASSWORD=

# --- Holehe provider ---
# Path to the local holehe clone (defaults to ./external/holehe).
HOLEHE_PROJECT_PATH=

# --- WhatsApp provider ---
# URL of the Baileys sidecar (services/providers/whatsapp/baileys-service/).
# That's a separate Node process you start yourself — see its README for the
# one-time QR-code login. This provider is just an HTTP proxy to it.
WHATSAPP_BAILEYS_URL=http://localhost:3025

# --- WhatsMyName provider ---
# Path to the local WhatsMyName clone (defaults to ./external/WhatsMyName).
# Only its wmn-data.json detection dataset is read; no install needed.
WHATSMYNAME_PROJECT_PATH=

# --- Ignorant provider ---
# Path to the local ignorant clone (defaults to ./external/ignorant).
IGNORANT_PROJECT_PATH=

# --- Social Analyzer provider ---
# Path to the local social-analyzer clone (defaults to ./external/social-analyzer).
SOCIALANALYZER_PROJECT_PATH=

# --- GHunt provider ---
# Path to the local GHunt clone (defaults to ./external/GHunt).
GHUNT_PROJECT_PATH=
# GHunt session file from `ghunt login` (defaults to ~/.malfrats/ghunt/creds.m).
# Without a valid session only the credential-free registration check runs.
GHUNT_CREDS_PATH=

# --- Content profiler tone backend (optional; degrades without it) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Image metadata analyzer (:8018) ---
# No config/creds. It uses PyExifTool, which shells out to the `exiftool` CLI
# (a Perl program) — install that binary separately and put it on PATH (see
# README). Without it the service still runs and reports exiftool_available:false.
